# Variables que el backend GOrbitS espera en runtime (perfil mysql,prod).
# El equipo de servidor/DevOps las define en su propio config/env o systemd.
# No incluir secretos reales en el repositorio.

JWT_SECRET=          # obligatorio, mínimo 32 caracteres
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_URL=jdbc:mariadb://127.0.0.1:3306/gorbits?characterEncoding=UTF-8&serverTimezone=UTC

# Opcionales (valores por defecto del código)
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=mysql,prod
